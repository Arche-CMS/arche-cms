{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/.vitepress/cache/**",
    "packages/cms/src/admin/**",
    "packages/generators/test/**",
    "apps/test-cms/cms/collections/posts.ts",
    "packages/create-app/explicit/cms/collections/posts.ts",
    "packages/create-app/my-cms/cms/collections/posts.ts",
    "packages/create-app/my-value/cms/collections/posts.ts"
  ],
  "ignoreDependencies": [
    "@arche-cms/types",
    "@arche-cms/core",
    "@arche-cms/database",
    "@arche-cms/rest-api",
    "@arche-cms/schema",
    "@arche-cms/validation",
    "@arche-cms/cms",
    "clsx",
    "lucide-react",
    "react",
    "tailwind-merge",
    "@tailwindcss/vite",
    "@tanstack/react-query",
    "dompurify",
    "@types/dompurify",
    "marked",
    "@types/marked"
  ],
  "audit": {
    "gate": "new-only"
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 30,
    "maxUnitSize": 150,
    "maxCrap": 400,
    "ignore": ["packages/*/test/**/*.test.ts", "apps/*/test/**/*.test.ts"],
    "thresholdOverrides": [
      {
        "files": ["packages/cms/src/server/routes/schemas.ts"],
        "maxUnitSize": 500,
        "reason": "auto-generated route registration"
      },
      {
        "files": ["packages/cms/src/server/routes/media.ts"],
        "maxUnitSize": 350,
        "reason": "media route handler with DB queries"
      },
      {
        "files": ["packages/cms/src/index.ts"],
        "maxUnitSize": 200,
        "maxCyclomatic": 45,
        "maxCognitive": 65,
        "maxCrap": 2000,
        "reason": "command-line arg parser with multiple subcommands"
      },
      {
        "files": ["packages/database/src/migration-generator.ts"],
        "maxCyclomatic": 20,
        "maxCognitive": 35,
        "maxUnitSize": 250,
        "reason": "table migration generator handles both collections and globals"
      },
      {
        "files": ["packages/generators/src/migrations.ts"],
        "maxCyclomatic": 25,
        "reason": "field-to-column mapping has many type branches"
      },
      {
        "files": ["packages/validation/src/generator.ts"],
        "maxCyclomatic": 45,
        "maxCognitive": 30,
        "reason": "field-to-Zod mapping with regex validation for each field type"
      }
    ]
  },
  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "skipLocal": true,
    "threshold": 5.0,
    "ignore": [
      "packages/cms/src/server/**",
      "packages/graphql/src/resolvers.ts",
      "packages/rest-api/src/handlers.ts",
      "packages/graphql/src/types.ts"
    ]
  },
  "entry": ["packages/cms/src/admin/main.tsx", "packages/*/src/index.ts"]
}
