{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "exclude": ["files", "duplicates"],
  "ignoreDependencies": ["@arche-cms/*", "@libsql/client", "drizzle-orm", "pg", "vue", "zod"],
  "ignoreFiles": [
    "**/test/**",
    "**/__generated__/**",
    "**/dist/**",
    "packages/create-app/explicit/**",
    "packages/create-app/my-cms/**",
    "packages/create-app/my-value/**"
  ],
  "ignoreIssues": {
    "packages/cms/src/admin/**": ["exports", "types"],
    "packages/cms/src/server/schemas/**": ["exports", "types"],
    "packages/cms/src/server/lib/**": ["exports", "types"],
    "packages/graphql/src/types.ts": ["exports", "types"],
    "packages/types/src/schema.ts": ["types"],
    "packages/admin-ui/src/lib/providers/**": ["exports", "types"],
    "packages/admin-ui/src/lib/api.ts": ["exports", "types"],
    "packages/cms-firebase/src/content.ts": ["exports", "types"]
  },
  "workspaces": {
    ".": {
      "entry": [
        "packages/*/src/index.{ts,tsx}",
        "packages/cms/src/admin/main.tsx",
        "packages/cms/src/server/app.ts",
        "packages/cms/src/server/config.ts",
        "apps/docs/.vitepress/config.ts"
      ]
    }
  }
}
