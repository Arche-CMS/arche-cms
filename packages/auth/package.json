{
  "name": "@arche-cms/auth",
  "version": "0.1.5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=30000",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arche-cms/database": "workspace:*",
    "@arche-cms/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arche-CMS/arche-cms.git",
    "directory": "packages/auth"
  }
}
