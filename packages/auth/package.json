{
  "name": "@altrugenix/auth",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=30000",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@altrugenix/database": "workspace:*",
    "@altrugenix/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0"
  }
}
