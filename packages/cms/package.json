{
  "name": "@arche-cms/cms",
  "version": "0.1.12",
  "type": "module",
  "bin": "bin/cms.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server/app": "./src/server/app.ts",
    "./server/config": "./src/server/config.ts"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arche-cms/admin-ui": "workspace:*",
    "@arche-cms/auth": "workspace:*",
    "@arche-cms/core": "workspace:*",
    "@arche-cms/database": "workspace:*",
    "@arche-cms/generators": "workspace:*",
    "@arche-cms/graphql": "workspace:*",
    "@arche-cms/permissions": "workspace:*",
    "@arche-cms/plugins": "workspace:*",
    "@arche-cms/rest-api": "workspace:*",
    "@arche-cms/schema": "workspace:*",
    "@arche-cms/storage": "workspace:*",
    "@arche-cms/types": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.2",
    "graphql": "^16.0.0",
    "mercurius": "^16.9.0"
  },
  "devDependencies": {
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "@libsql/client": "^0.17.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arche-CMS/arche-cms.git",
    "directory": "packages/cms"
  }
}
