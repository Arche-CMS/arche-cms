{
  "name": "@arche-cms/cms",
  "version": "0.1.6",
  "type": "module",
  "bin": "bin/cms.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/server/app.js": "./src/server/app.js",
    "./src/server/config.js": "./src/server/config.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:admin": "vite build --config src/admin/vite.config.ts",
    "build": "pnpm build:admin && tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arche-cms/auth": "workspace:*",
    "@arche-cms/core": "workspace:*",
    "@arche-cms/database": "workspace:*",
    "@arche-cms/generators": "workspace:*",
    "@arche-cms/graphql": "workspace:*",
    "@arche-cms/permissions": "workspace:*",
    "@arche-cms/plugins": "workspace:*",
    "@arche-cms/rest-api": "workspace:*",
    "@arche-cms/schema": "workspace:*",
    "@arche-cms/storage": "workspace:*",
    "@arche-cms/types": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.114.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.2",
    "graphql": "^16.0.0",
    "lucide-react": "^0.554.0",
    "marked": "^18.0.6",
    "mercurius": "^16.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4"
  },
  "peerDependencies": {
    "@libsql/client": "^0.17.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arche-CMS/arche-cms.git",
    "directory": "packages/cms"
  }
}
