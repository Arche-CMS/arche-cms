{
  "name": "@altrugenix/cms",
  "version": "0.0.1",
  "type": "module",
  "bin": "./bin/cms.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@altrugenix/auth": "workspace:*",
    "@altrugenix/core": "workspace:*",
    "@altrugenix/database": "workspace:*",
    "@altrugenix/generators": "workspace:*",
    "@altrugenix/graphql": "workspace:*",
    "@altrugenix/permissions": "workspace:*",
    "@altrugenix/plugins": "workspace:*",
    "@altrugenix/rest-api": "workspace:*",
    "@altrugenix/schema": "workspace:*",
    "@altrugenix/storage": "workspace:*",
    "@altrugenix/types": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "fastify": "^5.3.2",
    "graphql": "^16.0.0",
    "mercurius": "^16.9.0"
  }
}
