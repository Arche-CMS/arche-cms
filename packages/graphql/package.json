{
  "name": "@altrugenix/graphql",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@altrugenix/database": "workspace:*",
    "@altrugenix/types": "workspace:*",
    "@altrugenix/validation": "workspace:*"
  },
  "peerDependencies": {
    "graphql": "^16.0.0",
    "mercurius": "^16.9.0"
  }
}
